# Core runtime
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/surgical_cal
SECRET_KEY=change-me-and-keep-matched-with-cal-if-using-shared-sso
BASE_URL=http://127.0.0.1:3010
CAL_URL=https://cal.midfloridasurgical.com

# AI/OCR providers
OLLAMA_BASE=http://127.0.0.1:11434
VISION_MODEL=qwen2.5vl:7b
TEXT_MODEL=llama3.2:3b
VISION_PROVIDER=paddle

# RVU behavior
RVU_LOCK_LOCAL_ONLY=true
RVU_DEFAULT_CF=41.0
RVU_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
RVU_COOKIE_SECURE=false

# Email (optional in local, required in production if email features are used)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@midfloridasurgical.com
